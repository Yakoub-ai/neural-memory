{
  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/context.sh\"",
          "timeout": 10
        }
      ]
    }
